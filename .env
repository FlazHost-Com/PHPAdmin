# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=PHPAdmin
APP_ENV=development
# Modes: full (sessions+CSRF+Redis) | api (API-only, no session)
APP_MODE=full
APP_URL=http://localhost:8001

# ─── Database ─────────────────────────────────────────────────────────────────
# Drivers: mysql | pgsql | sqlite
DB_DRIVER=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=./dev.sqlite3
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Session & Auth ───────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_at_least_32_characters_long
SESSION_TTL_HOURS=6
JWT_SECRET=change_me_to_at_least_32_characters_long
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=10
OTP_EXPIRY_MINUTES=10
DEFAULT_PAGE_SIZE=10

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=PHPAdmin

# ─── Storage / OSS (S3-compatible file manager) ───────────────────────────────
# Drivers: oss | s3 | local
STORAGE_DRIVER=oss
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_REGION=us-east-1
STORAGE_SSL=true
# false = virtual-hosted style (AWS S3, Alibaba OSS, DigitalOcean Spaces)
# true  = path-style (MinIO local, some other S3-compat)
STORAGE_PATH_STYLE=false
STORAGE_BASE_URL=

# ─── Timezone ─────────────────────────────────────────────────────────────────
TZ=UTC
